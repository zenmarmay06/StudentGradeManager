{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "JwtSettings": {
    "Secret": "your-256-bit-secret",
    "ExpirationInMinutes": 60
  },
  "Jwt": {
    "Issuer": "your-app-name",
    "Audience": "your-app-audience",
    "SecretKey": "your-very-long-secret-key"
  },
  "AllowedHosts": "*"
}


